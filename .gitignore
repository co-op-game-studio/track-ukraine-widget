node_modules/
dist/
.env
.dev.vars
*.local

# FR-45 AC-45.6: coverage artifacts (regenerated by npm run test:coverage*)
coverage/

# Wrangler local state cache (per-machine; never committed).
.wrangler/

# Local debug / profiling artifacts. If you need to capture an API payload
# or a CPU profile, name it with one of these patterns so it never lands
# in a commit by accident.
*.profile.json
scratch.*
tmp.*

# Specific one-off debug files that have escaped into the tree at least
# once — explicit gitignore entries so they don't come back.
body.json
prof.json
rc.json
st.json
stg-test.html
perf-test.html
